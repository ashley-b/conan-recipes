root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
tab_width = 4
trim_trailing_whitespace = true

# Ignore diffs and patches
[*.{diff,patch}]
charset = unset
end_of_line = unset
indent_style = unset
insert_final_newline = unset
tab_width = unset
trim_trailing_whitespace = unset

[*.md]
tab_width = 2
trim_trailing_whitespace = false

[*.py]
max_line_length = 200

[*.yml]
tab_width = 2
