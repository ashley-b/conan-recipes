root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
tab_width = 4
trim_trailing_whitespace = true

[*.md]
tab_width = 2
trim_trailing_whitespace = false

[*.py]
max_line_length = 200

[*.yml]
tab_width = 2

[*.{diff,patch}]
trim_trailing_whitespace = false
